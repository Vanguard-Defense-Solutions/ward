{
  "name": "ward-monorepo",
  "private": true,
  "workspaces": ["packages/*"],
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:unit": "vitest run --reporter=verbose --testPathPattern=unit",
    "test:e2e": "vitest run --reporter=verbose --testPathPattern=e2e",
    "build": "bun run --filter '*' build",
    "lint": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0",
    "yaml": "^2.8.3"
  }
}
